OPENPHONIC_DATA_DIR=./data
OPENPHONIC_DATABASE_PATH=./data/openphonic.sqlite3
OPENPHONIC_PIPELINE_CONFIG=./config/default.yml
OPENPHONIC_PRESET_DIR=./data/presets
OPENPHONIC_MAX_UPLOAD_MB=1024
OPENPHONIC_RETENTION_DAYS=0
OPENPHONIC_PUBLIC_BASE_URL=http://127.0.0.1:8000

# Optional model settings
HF_TOKEN=
OPENPHONIC_WHISPER_MODEL=small
OPENPHONIC_WHISPER_DEVICE=auto
OPENPHONIC_PYANNOTE_MODEL=pyannote/speaker-diarization-3.1
OPENPHONIC_DEEPFILTERNET_BIN=deepFilter
